# MongoDB Atlas connection string (required — set this in Vercel dashboard too)
MONGO_URI=your_mongodb_atlas_connection_string_here

# Only needed for local dev if you run the API on a different port/host.
# Leave unset in production — the frontend will call /api on the same domain.
VITE_API_URL=

# Email notifications (optional — form still works and saves to MongoDB
# without these, you just won't get an email). Get a free key at resend.com.
RESEND_API_KEY=your_resend_api_key_here
NOTIFY_EMAIL=your_email_here@example.com
